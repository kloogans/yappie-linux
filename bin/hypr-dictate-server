#!/usr/bin/env python3
"""Persistent dictation server with pluggable backends.

Listens on a unix socket for audio file paths, transcribes them, and
returns the text. The model stays loaded between requests so subsequent
transcriptions are fast (~150ms).

Configuration via ~/.config/hypr-dictate/config (shell-sourceable):
    BACKEND=faster-whisper    # faster-whisper, moonshine, or parakeet
    MODEL=large-v3-turbo
    DEVICE=cuda
    COMPUTE_TYPE=int8
    BEAM_SIZE=1
    VAD_FILTER=true
"""
import os, sys, socket


# ---------------------------------------------------------------------------
# Backends — each one implements load() and transcribe(audio_path)
# ---------------------------------------------------------------------------

class FasterWhisperBackend:
    """faster-whisper via CTranslate2. Best overall for GPU."""

    def __init__(self, config):
        from faster_whisper import WhisperModel

        self.model = WhisperModel(
            config["MODEL"],
            device=config["DEVICE"],
            compute_type=config["COMPUTE_TYPE"],
        )
        self.beam_size = int(config["BEAM_SIZE"])
        self.vad_filter = config["VAD_FILTER"].lower() == "true"

    def transcribe(self, audio_path):
        segments, _ = self.model.transcribe(
            audio_path, beam_size=self.beam_size, vad_filter=self.vad_filter
        )
        return " ".join(seg.text.strip() for seg in segments)


class MoonshineBackend:
    """Moonshine ONNX. Lightweight, runs well on CPU."""

    def __init__(self, config):
        from moonshine_onnx import MoonshineOnnxModel, load_tokenizer

        model_name = config.get("MODEL", "moonshine/base")
        if "/" not in model_name:
            model_name = f"moonshine/{model_name}"
        self.model = MoonshineOnnxModel(model_name=model_name)
        self.tokenizer = load_tokenizer()

    def transcribe(self, audio_path):
        from moonshine_onnx import load_audio

        audio = load_audio(audio_path)
        tokens = self.model.generate(audio)
        return self.tokenizer.decode_batch(tokens)[0].strip()


class ParakeetBackend:
    """NVIDIA Parakeet-TDT via NeMo. Best accuracy-to-size ratio."""

    def __init__(self, config):
        import nemo.collections.asr as nemo_asr

        model_name = config.get("MODEL", "nvidia/parakeet-tdt-0.6b-v2")
        self.model = nemo_asr.models.ASRModel.from_pretrained(model_name=model_name)
        device = config.get("DEVICE", "cuda")
        if device == "cpu":
            self.model = self.model.cpu()

    def transcribe(self, audio_path):
        result = self.model.transcribe([audio_path])
        if isinstance(result, tuple):
            result = result[0]
        return result[0].strip() if result else ""


BACKENDS = {
    "faster-whisper": FasterWhisperBackend,
    "moonshine": MoonshineBackend,
    "parakeet": ParakeetBackend,
}

# Default configs per backend (overridden by user config)
BACKEND_DEFAULTS = {
    "faster-whisper": {
        "MODEL": "large-v3-turbo",
        "DEVICE": "cuda",
        "COMPUTE_TYPE": "int8",
        "BEAM_SIZE": "1",
        "VAD_FILTER": "true",
    },
    "moonshine": {
        "MODEL": "moonshine/base",
        "DEVICE": "cpu",
        "COMPUTE_TYPE": "",
        "BEAM_SIZE": "",
        "VAD_FILTER": "",
    },
    "parakeet": {
        "MODEL": "nvidia/parakeet-tdt-0.6b-v2",
        "DEVICE": "cuda",
        "COMPUTE_TYPE": "",
        "BEAM_SIZE": "",
        "VAD_FILTER": "",
    },
}


def load_config():
    config_dir = os.path.join(
        os.environ.get("XDG_CONFIG_HOME", os.path.expanduser("~/.config")),
        "hypr-dictate",
    )
    config_file = os.path.join(config_dir, "config")

    # Start with user values from file
    user_config = {}
    if os.path.exists(config_file):
        with open(config_file) as f:
            for line in f:
                line = line.strip()
                if line and not line.startswith("#") and "=" in line:
                    key, _, val = line.partition("=")
                    user_config[key.strip()] = val.strip().strip('"').strip("'")

    # Determine backend, then layer: backend defaults < user overrides
    backend_name = user_config.get("BACKEND", "faster-whisper")
    defaults = BACKEND_DEFAULTS.get(backend_name, BACKEND_DEFAULTS["faster-whisper"])

    config = {**defaults, "BACKEND": backend_name, "CUDA_LIB_PATH": ""}
    config.update(user_config)
    return config


def main():
    config = load_config()
    runtime_dir = os.environ.get("XDG_RUNTIME_DIR", "/tmp")

    # Set up CUDA library path if specified (re-exec once to inherit LD_LIBRARY_PATH)
    cuda_path = config.get("CUDA_LIB_PATH", "")
    if cuda_path and not os.environ.get("_HYPR_DICTATE_REEXEC"):
        os.environ["LD_LIBRARY_PATH"] = (
            cuda_path + ":" + os.environ.get("LD_LIBRARY_PATH", "")
        )
        os.environ["_HYPR_DICTATE_REEXEC"] = "1"
        os.execv(sys.executable, [sys.executable] + sys.argv)

    backend_name = config["BACKEND"]
    if backend_name not in BACKENDS:
        print(
            f"Unknown backend: {backend_name}. "
            f"Available: {', '.join(BACKENDS.keys())}",
            file=sys.stderr,
        )
        sys.exit(1)

    sock_path = os.path.join(runtime_dir, "hypr-dictate.sock")

    print(f"Loading {backend_name} ({config['MODEL']})...", flush=True)
    backend = BACKENDS[backend_name](config)
    print(f"Ready, listening on {sock_path}", flush=True)

    if os.path.exists(sock_path):
        os.remove(sock_path)

    server = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    server.bind(sock_path)
    server.listen(1)

    while True:
        conn, _ = server.accept()
        try:
            audio_path = conn.recv(4096).decode().strip()
            if not audio_path or not os.path.exists(audio_path):
                conn.sendall(b"")
                continue
            text = backend.transcribe(audio_path)
            conn.sendall(text.encode())
        except Exception as e:
            print(f"Error: {e}", flush=True)
            conn.sendall(f"ERROR:{e}".encode())
        finally:
            conn.close()


if __name__ == "__main__":
    main()
