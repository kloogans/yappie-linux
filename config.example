# hypr-dictate configuration
# Copy to ~/.config/hypr-dictate/config

# Backend: faster-whisper, moonshine, or parakeet
BACKEND=faster-whisper

# Model name (depends on backend)
#   faster-whisper: large-v3-turbo, large-v3, small, base, tiny
#   moonshine:      moonshine/base, moonshine/tiny
#   parakeet:       nvidia/parakeet-tdt-0.6b-v2
MODEL=large-v3-turbo

# Device: cuda, cpu, or auto (faster-whisper and parakeet only)
DEVICE=cuda

# Quantization: float16, int8, or float32 (faster-whisper only)
COMPUTE_TYPE=int8

# Beam size: 1 is fastest, 5 is most accurate (faster-whisper only)
BEAM_SIZE=1

# Voice activity detection: skips silence (faster-whisper only)
VAD_FILTER=true

# CUDA library path override (leave empty for system default)
# CUDA_LIB_PATH=/usr/local/cuda/lib64
